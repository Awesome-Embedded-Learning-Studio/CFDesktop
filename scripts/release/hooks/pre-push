#!/bin/bash
# =============================================================================
# Git Pre-Push Hook - Version Check
# =============================================================================
#
# Install: bash scripts/release/hooks/install_hooks.sh
#
# Behavior:
#   - main/release branches: verify CMakeLists.txt version has changed
#   - other branches: skip
#
# Build & test validation is handled by remote CI (GitHub Actions).
# Bypass: git push --no-verify
# =============================================================================

set -e

# =============================================================================
# Colors
# =============================================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# =============================================================================
# Logging
# =============================================================================
log_info() {
    echo -e "${BLUE}>>>${NC} $1"
}

log_success() {
    echo -e "${GREEN}✓${NC} $1"
}

log_error() {
    echo -e "${RED}✗${NC} $1"
}

# =============================================================================
# Project root
# =============================================================================
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Position-independent: works under core.hooksPath (scripts/release/hooks/) or .git/hooks/
PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -z "$PROJECT_ROOT" ] && PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
cd "$PROJECT_ROOT"

# =============================================================================
# Load version utilities
# =============================================================================
VERSION_UTILS="$PROJECT_ROOT/scripts/release/hooks/version_utils.sh"
if [[ -f "$VERSION_UTILS" ]]; then
    source "$VERSION_UTILS"
else
    log_error "Version utilities not found: $VERSION_UTILS"
    exit 1
fi

# =============================================================================
# Detect current branch
# =============================================================================
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

if [[ -z "$CURRENT_BRANCH" ]]; then
    while read local_ref local_sha remote_ref remote_sha; do
        CURRENT_BRANCH=$(echo "$local_ref" | sed 's|refs/heads/||')
        break
    done < /dev/stdin
fi

# =============================================================================
# Branch predicates
# =============================================================================
is_main_branch() {
    [[ "$CURRENT_BRANCH" == "main" ]]
}

is_release_branch() {
    [[ "$CURRENT_BRANCH" == release/* ]]
}

should_verify() {
    is_main_branch || is_release_branch
}

# =============================================================================
# Version check (main and release branches only)
# =============================================================================
check_version_changed() {
    if ! should_verify; then
        return 0
    fi

    LOCAL_CMAKE_VERSION=$(get_cmake_version "$PROJECT_ROOT")
    REMOTE_CMAKE_VERSION=$(get_remote_cmake_version "origin/main")

    if [[ -z "$REMOTE_CMAKE_VERSION" ]]; then
        log_info "First push to remote, skipping version check"
        return 0
    fi

    if [[ "$LOCAL_CMAKE_VERSION" == "$REMOTE_CMAKE_VERSION" ]]; then
        echo ""
        log_error "========================================"
        log_error "Version unchanged, push blocked"
        log_error "========================================"
        echo ""
        echo -e "Local:  ${YELLOW}$LOCAL_CMAKE_VERSION${NC}"
        echo -e "Remote: ${YELLOW}$REMOTE_CMAKE_VERSION${NC}"
        echo ""
        echo "Pushing to main/release requires a version bump in CMakeLists.txt."
        echo ""
        echo "  1. Update CMakeLists.txt:"
        echo -e "     ${CYAN}project(CFDesktop VERSION X.Y.Z LANGUAGES CXX)${NC}"
        echo ""
        echo "Version rules:"
        echo "  - Patch: 0.13.1 -> 0.13.2 (bug fixes)"
        echo "  - Minor: 0.13.1 -> 0.14.0 (new features)"
        echo "  - Major: 0.13.1 -> 1.0.0  (breaking changes)"
        echo ""
        echo -e "${YELLOW}Bypass with --no-verify (not recommended)${NC}"
        echo ""
        return 1
    fi

    log_success "Version check passed: $LOCAL_CMAKE_VERSION (remote: $REMOTE_CMAKE_VERSION)"
    return 0
}

# =============================================================================
# Run version check
# =============================================================================
if ! check_version_changed; then
    exit 1
fi

# =============================================================================
# Non-protected branches: skip
# =============================================================================
if ! should_verify; then
    echo ""
    log_info "Pre-Push: branch '$CURRENT_BRANCH' — version check skipped"
    echo ""
    exit 0
fi

echo ""
log_info "Pre-Push: branch '$CURRENT_BRANCH' — version check passed"
log_info "Build & test validation will run in remote CI"
echo ""
